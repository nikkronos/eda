# Скопируй в .env и заполни. Никогда не коммить .env.

# Токен бота из @BotFather (после /revoke — только свежий!)
TELEGRAM_BOT_TOKEN=

# Ключ Anthropic API (console.anthropic.com), модель — Haiku, копейки
ANTHROPIC_API_KEY=

# Кто имеет доступ: telegram_id:Имя через запятую (имена видит LLM для контекста)
USERS=111111111:Никита,222222222:Богдан

# Смещение таймзоны от UTC (МСК = 3)
TZ_OFFSET=3

# Путь к базе (относительно корня проекта)
DB_PATH=data/eda.db

# Модель для разбора сообщений
LLM_MODEL=claude-haiku-4-5
